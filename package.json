{
  "name": "promoterhub",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm dev:server",
    "dev:server": "cross-env NODE_ENV=development tsx watch server/_core/index.ts",
    "build": "pnpm build:web && esbuild server/_core/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "start": "NODE_ENV=production node dist/index.js",
    "check": "tsc --noEmit",
    "format": "prettier --write .",
    "test": "vitest run",
    "db:push": "drizzle-kit generate && drizzle-kit migrate",
    "build:web": "cross-env NODE_ENV=production pnpm --filter ./web build"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.21",
    "@trpc/client": "^11.7.2",
    "@trpc/react-query": "^11.7.2",
    "@trpc/server": "^11.7.2",
    "@types/bcryptjs": "^3.0.0",
    "@types/multer": "^2.0.0",
    "axios": "^1.13.2",
    "bcryptjs": "^3.0.3",
    "cookie": "^1.1.1",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.44.7",
    "express": "^4.22.1",
    "jose": "6.1.0",
    "multer": "^2.0.2",
    "mysql2": "^3.16.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "superjson": "^1.13.3",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/cookie": "^0.6.0",
    "@types/express": "^4.17.25",
    "@types/node": "^22.19.3",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "cross-env": "^7.0.3",
    "drizzle-kit": "^0.31.8",
    "esbuild": "^0.25.12",
    "prettier": "^3.7.4",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vitest": "^2.1.9"
  },
  "packageManager": "pnpm@9.12.0"
}
